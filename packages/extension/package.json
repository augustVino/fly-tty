{
  "name": "fly-tty",
  "version": "0.2.0",
  "description": "Fly TTY Extension for Cursor/VS Code",
  "displayName": "Fly TTY",
  "publisher": "vino",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/augustVino/fly-tty"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "terminal",
    "ghostty",
    "iterm2",
    "split",
    "workspace",
    "automation",
    "tui",
    "layout"
  ],
  "engines": {
    "vscode": "^1.96.0"
  },
  "activationEvents": [
    "onCommand:flyTty.openProject"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flyTty.openProject",
        "title": "Fly TTY: Open Project",
        "icon": {
          "light": "media/icon-light.svg",
          "dark": "media/icon-dark.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "flyTty.openProject",
          "group": "navigation",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "configuration": {
      "title": "Fly TTY",
      "properties": {
        "flyTty.terminal": {
          "type": "string",
          "enum": [
            "ghostty",
            "iterm2"
          ],
          "default": "ghostty",
          "description": "Terminal application to use for workspace sync"
        },
        "flyTty.terminalPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to the terminal application (e.g. /Applications/Ghostty.app). Leave empty to use the default."
        },
        "flyTty.layout": {
          "type": "object",
          "description": "Terminal layout configuration. Example: { \"direction\": \"vertical\", \"panes\": [{ \"id\": \"left\", \"commands\": [\"vim\"] }, { \"id\": \"right\" }] }"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "typecheck": "tsc --noEmit",
    "test": "echo 'Tests are in the root tests/ directory'"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2"
  }
}
