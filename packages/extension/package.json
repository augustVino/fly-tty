{
  "name": "ide-tui-bridge",
  "version": "0.1.2",
  "description": "IDE-TUI Bridge Extension for Cursor/VS Code",
  "displayName": "IDE-TUI Bridge",
  "publisher": "vino",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/augustVino/ide-tui-bridge"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "terminal",
    "ghostty",
    "iterm2",
    "split",
    "workspace",
    "automation",
    "tui",
    "layout"
  ],
  "engines": {
    "vscode": "^1.96.0"
  },
  "activationEvents": [
    "onCommand:ideTuiBridge.openProject"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ideTuiBridge.openProject",
        "title": "Workspace Sync: Open Project",
        "icon": {
          "light": "media/icon-light.svg",
          "dark": "media/icon-dark.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ideTuiBridge.openProject",
          "group": "navigation",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "configuration": {
      "title": "IDE-TUI Bridge",
      "properties": {
        "ideTuiBridge.terminal": {
          "type": "string",
          "enum": [
            "ghostty",
            "iterm2"
          ],
          "default": "ghostty",
          "description": "Terminal application to use for workspace sync"
        },
        "ideTuiBridge.terminalPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to the terminal application (e.g. /Applications/Ghostty.app). Leave empty to use the default."
        },
        "ideTuiBridge.layout": {
          "type": "object",
          "description": "Terminal layout configuration. Example: { \"direction\": \"vertical\", \"panes\": [{ \"id\": \"left\", \"commands\": [\"vim\"] }, { \"id\": \"right\" }] }"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "typecheck": "tsc --noEmit",
    "test": "echo 'Tests are in the root tests/ directory'"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2"
  }
}
