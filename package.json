{
  "name": "fly-tty",
  "version": "0.0.1",
  "description": "Fly TTY: Instant workspace sync between IDE and terminal",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npx vitest run tests/ --reporter=verbose",
    "test:coverage": "npx vitest run --coverage tests/",
    "typecheck": "tsc --build",
    "pack": "cd packages/extension && npm run build && npm run package"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
