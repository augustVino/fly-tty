{
  "name": "ide-tui-bridge",
  "version": "0.1.0",
  "description": "IDE-TUI Bridge: Sync workspace layout between IDE and terminal",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npx vitest run tests/ --reporter=verbose",
    "test:coverage": "npx vitest run --coverage tests/",
    "typecheck": "tsc --build --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
